<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefWidth="960" prefHeight="650" xmlns:fx="http://javafx.com/fxml" fx:controller="com.linkx.client.MainController">
    <left>
        <VBox prefWidth="68" style="-fx-background-color: #2e2e2e;" spacing="0" alignment="TOP_CENTER">
            <padding><Insets top="16" bottom="16"/></padding>

            <Label text="L" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #07c160;">
                <VBox.margin><Insets bottom="24"/></VBox.margin>
            </Label>

            <VBox spacing="4" alignment="CENTER">
                <Button fx:id="chatBtn" prefWidth="48" prefHeight="48" styleClass="icon-btn">
                    <graphic>
                        <Label text="消息" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 11px;"/>
                    </graphic>
                </Button>
                <Button fx:id="contactsBtn" prefWidth="48" prefHeight="48" styleClass="icon-btn">
                    <graphic>
                        <Label text="通讯录" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 11px;"/>
                    </graphic>
                </Button>
                <Button fx:id="profileBtn" prefWidth="48" prefHeight="48" styleClass="icon-btn">
                    <graphic>
                        <Label text="我" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 11px;"/>
                    </graphic>
                </Button>
            </VBox>

            <VBox VBox.vgrow="ALWAYS"/>

            <Button fx:id="logoutBtn" prefWidth="48" prefHeight="36" styleClass="icon-btn">
                <graphic>
                    <Label text="退出" style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 10px;"/>
                </graphic>
                <VBox.margin><Insets bottom="8"/></VBox.margin>
            </Button>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #f5f5f5;"/>
    </center>
</BorderPane>
