# =============================================================================
# LinkX environment (copy to .env and edit)
#
# Phase 1 - Local dev (IDE + mvn + npm run dev):
#   docker compose -f docker-compose.dev.yml up -d
#   LINKX_PROFILE=dev (default in application.yml)
#   See .env.dev.example for suggested values when using dev compose.
#
# Phase 2 - Single-machine "prod simulation" (full stack):
#   docker compose up -d --build
#   LINKX_PROFILE=prod, strong secrets, CAPTCHA=true, CORS filled in.
# =============================================================================

LINKX_COMPOSE_PROJECT=linkx
LINKX_TIMEZONE=Asia/Shanghai

# Runtime profile: dev | prod
LINKX_PROFILE=prod
LINKX_SERVER_PORT=8080
LINKX_API_BASE_URL=http://localhost:8080
# Stored file URL prefix in DB metadata (access is via /api/file/access/{ticket})
LINKX_UPLOAD_URL=http://localhost:8080/uploads/

# Database (required for docker compose)
LINKX_DB_PORT=3306
LINKX_DB_NAME=linkx_im
LINKX_DB_USERNAME=linkx
LINKX_DB_PASSWORD=change_me_linkx_db_password
LINKX_DB_ROOT_PASSWORD=change_me_linkx_root_password

# Redis (required for rate limit, captcha, logout denylist, refresh sessions)
LINKX_REDIS_PORT=6379
LINKX_REDIS_PASSWORD=change_me_linkx_redis_password

# JWT (prod: random 32+ chars; placeholder will fail ProductionSecurityStartupValidator)
LINKX_JWT_SECRET=PLEASE_CHANGE_ME_LINKX_JWT_SECRET_2026_32CHARS_MIN
LINKX_JWT_EXPIRATION=86400000
LINKX_JWT_REFRESH_EXPIRATION=604800000

# CORS (prod required). Comma-separated, no spaces unless part of URL:
# LINKX_SECURITY_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173
LINKX_SECURITY_ALLOWED_ORIGIN_PATTERNS=

# Auth rate limit
LINKX_SECURITY_AUTH_RATE_LIMIT_ENABLED=true
LINKX_SECURITY_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
LINKX_SECURITY_AUTH_LOGIN_MAX_REQUESTS=10
LINKX_SECURITY_AUTH_REGISTER_MAX_REQUESTS=5
LINKX_SECURITY_AUTH_REFRESH_MAX_REQUESTS=20
LINKX_SECURITY_AUTH_CAPTCHA_ISSUE_MAX_REQUESTS=30

# Captcha: false for local IDE dev; true for prod / docker full stack simulation
LINKX_SECURITY_CAPTCHA_ENABLED=false

# Set true when behind Nginx/SLB that sets X-Forwarded-For (trusted proxy only)
LINKX_SECURITY_TRUSTED_PROXY_ENABLED=false

# Abuse protection (user search + friend requests)
LINKX_SECURITY_ABUSE_PROTECTION_ENABLED=true
LINKX_SECURITY_USER_SEARCH_WINDOW_SECONDS=60
LINKX_SECURITY_USER_SEARCH_MAX_PER_USER=30
LINKX_SECURITY_USER_SEARCH_MAX_PER_IP=60
LINKX_SECURITY_FRIEND_REQUEST_MAX_PER_USER_DAY=20
LINKX_SECURITY_FRIEND_REQUEST_MAX_PER_IP_DAY=50