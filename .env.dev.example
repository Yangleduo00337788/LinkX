# Suggested .env for Phase 1: docker compose -f docker-compose.dev.yml up -d
# Copy:  copy .env.dev.example .env
# Backend: LINKX_PROFILE=dev (default), mvn spring-boot:run in linkx-server
# Frontend: npm run dev in linkx-web (VITE_API_BASE_URL=http://localhost:8080)

LINKX_COMPOSE_PROJECT=linkx
LINKX_TIMEZONE=Asia/Shanghai

LINKX_PROFILE=dev
LINKX_DB_PORT=3306
LINKX_DB_NAME=linkx_im
LINKX_DB_USERNAME=linkx
LINKX_DB_PASSWORD=linkx_dev_password
LINKX_DB_ROOT_PASSWORD=linkx_dev_root

LINKX_REDIS_PORT=6379
LINKX_REDIS_PASSWORD=linkx_dev_redis

# When running server on host (not in Docker), point to containers:
# LINKX_DB_URL=jdbc:mysql://localhost:3306/linkx_im?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
# LINKX_REDIS_HOST=localhost

LINKX_SECURITY_CAPTCHA_ENABLED=false