<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefWidth="960" prefHeight="650" xmlns:fx="http://javafx.com/fxml" fx:controller="com.linkx.client.MainController">
    <left>
        <VBox prefWidth="220" styleClass="side-menu" spacing="0">
            <padding>
                <Insets top="24" right="0" bottom="24" left="0"/>
            </padding>

            <HBox alignment="CENTER" spacing="8">
                <padding>
                    <Insets bottom="32" left="24"/>
                </padding>
                <Label text="LinkX" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1890ff;"/>
                <Label text="IM" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </HBox>

            <Button fx:id="profileBtn" text="  我的资料" prefHeight="44" maxWidth="220" styleClass="menu-btn">
                <padding><Insets left="24"/></padding>
            </Button>
            <Button fx:id="contactsBtn" text="  联系人" prefHeight="44" maxWidth="220" styleClass="menu-btn">
                <padding><Insets left="24"/></padding>
            </Button>
            <Button fx:id="chatBtn" text="  消息" prefHeight="44" maxWidth="220" styleClass="menu-btn">
                <padding><Insets left="24"/></padding>
            </Button>

            <VBox VBox.vgrow="ALWAYS"/>

            <Button fx:id="logoutBtn" text="  退出登录" prefHeight="44" maxWidth="220" style="-fx-background-color: transparent; -fx-text-fill: #ff4d4f; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT;">
                <padding><Insets left="24"/></padding>
            </Button>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea">
            <padding>
                <Insets top="0" right="0" bottom="0" left="0"/>
            </padding>
        </StackPane>
    </center>
</BorderPane>
