<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="0" xmlns:fx="http://javafx.com/fxml" fx:controller="com.linkx.client.ProfileController" style="-fx-background-color: #f0f2f5;">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 8, 0, 0, 2);">
        <padding>
            <Insets top="32" right="32" bottom="32" left="32"/>
        </padding>

        <Label text="个人资料" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #262626;">
            <VBox.margin><Insets bottom="24"/></VBox.margin>
        </Label>

        <HBox spacing="24" alignment="CENTER_LEFT" VBox.vgrow="ALWAYS">
            <VBox spacing="8" alignment="CENTER">
                <ImageView fx:id="avatarView" fitWidth="88" fitHeight="88" preserveRatio="true" style="-fx-background-radius: 44; -fx-background-color: #f0f0f0;"/>
                <Button fx:id="changeAvatarBtn" text="更换头像" styleClass="primary-btn" prefHeight="28">
                    <VBox.margin><Insets top="4"/></VBox.margin>
                </Button>
            </VBox>

            <VBox spacing="16" VBox.vgrow="ALWAYS">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="用户名" styleClass="field-label"/>
                    <Label fx:id="usernameText" style="-fx-font-size: 14px; -fx-text-fill: #333;"/>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="昵称" styleClass="field-label"/>
                    <TextField fx:id="nicknameField" prefWidth="260" prefHeight="36" styleClass="input-field"/>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="性别" styleClass="field-label"/>
                    <ComboBox fx:id="genderBox" prefWidth="150" prefHeight="36" styleClass="input-field"/>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="注册时间" styleClass="field-label"/>
                    <Label fx:id="createTimeText" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                </HBox>
            </VBox>
        </HBox>

        <Separator style="-fx-padding: 16 0 16 0;"/>

        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button fx:id="saveBtn" text="保存修改" prefHeight="38" styleClass="primary-btn"/>
        </HBox>

        <Label fx:id="messageText" style="-fx-font-size: 12px; -fx-padding: 8 0 0 0;"/>
    </VBox>
</VBox>
