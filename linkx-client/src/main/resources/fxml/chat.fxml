<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.linkx.client.ChatController" style="-fx-background-color: #ededed;">
    <!-- 顶部栏 -->
    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #2e2e2e; -fx-padding: 0 20;">
            <padding><Insets top="12" bottom="12"/></padding>
            <Label fx:id="chatTargetLabel" text="消息" style="-fx-font-size: 16px; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- 左侧会话列表 -->
    <left>
        <VBox prefWidth="260" style="-fx-background-color: #e9e9e9;">
            <padding><Insets top="8" bottom="8"/></padding>
            <ListView fx:id="sessionList" VBox.vgrow="ALWAYS" style="-fx-background-color: #e9e9e9;"/>
        </VBox>
    </left>

    <!-- 右侧聊天区 -->
    <center>
        <VBox spacing="0">
            <!-- 消息列表 -->
            <ListView fx:id="messageList" VBox.vgrow="ALWAYS" style="-fx-background-color: #ededed;"/>

            <!-- 输入区域 -->
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-background-color: #f5f5f5; -fx-padding: 8 12;">
                <TextField fx:id="messageInput" promptText="输入消息..." HBox.hgrow="ALWAYS" prefHeight="34" styleClass="chat-input" onAction="#handleSend"/>
                <Button fx:id="sendBtn" text="发送" styleClass="send-btn" prefHeight="34"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
