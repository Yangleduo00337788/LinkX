<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="0" prefWidth="400" prefHeight="550" style="-fx-background-color: #f5f5f5;"
      xmlns:fx="http://javafx.com/fxml" fx:controller="com.linkx.client.RegisterController">
    <VBox alignment="CENTER" spacing="16" VBox.vgrow="ALWAYS">
        <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

        <Label text="LinkX IM" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #07c160;">
            <VBox.margin><Insets bottom="4"/></VBox.margin>
        </Label>
        <Label text="创建账号" style="-fx-font-size: 14px; -fx-text-fill: #999;"/>

        <VBox spacing="12">
            <TextField fx:id="usernameField" promptText="用户名（3-50位）" prefHeight="44" styleClass="wechat-login-input"/>
            <TextField fx:id="nicknameField" promptText="昵称" prefHeight="44" styleClass="wechat-login-input"/>
            <PasswordField fx:id="passwordField" promptText="密码（6位以上）" prefHeight="44" styleClass="wechat-login-input"/>
            <PasswordField fx:id="confirmPasswordField" promptText="确认密码" prefHeight="44" styleClass="wechat-login-input"/>
        </VBox>

        <VBox spacing="14">
            <Button fx:id="registerBtn" text="注 册" prefHeight="44" maxWidth="300" styleClass="wechat-green"/>
            <Button fx:id="backBtn" text="返回登录" prefHeight="44" maxWidth="300" styleClass="wechat-white"/>
        </VBox>

        <Label fx:id="errorText" style="-fx-text-fill: #ee0a24; -fx-font-size: 13px;"/>
    </VBox>
</VBox>
