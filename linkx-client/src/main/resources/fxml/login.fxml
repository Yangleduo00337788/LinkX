<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="24" prefWidth="400" prefHeight="500" style="-fx-background-color: linear-gradient(to bottom, #f0f5ff, #e6f7ff);">
    <padding>
        <Insets top="60" right="50" bottom="60" left="50"/>
    </padding>

    <Label text="LinkX IM" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #1890ff;">
        <VBox.margin>
            <Insets bottom="8"/>
        </VBox.margin>
    </Label>

    <Label text="安全稳定的即时通讯平台" style="-fx-font-size: 14px; -fx-text-fill: #999;">
        <VBox.margin>
            <Insets bottom="16"/>
        </VBox.margin>
    </Label>

    <VBox spacing="16">
        <TextField fx:id="usernameField" promptText="请输入用户名" prefHeight="42" styleClass="input-field"/>
        <PasswordField fx:id="passwordField" promptText="请输入密码" prefHeight="42" styleClass="input-field"/>
    </VBox>

    <VBox spacing="12">
        <Button fx:id="loginBtn" text="登  录" prefHeight="42" styleClass="primary-btn"/>
        <Button fx:id="registerBtn" text="注册新账号" prefHeight="42" styleClass="success-btn"/>
    </VBox>

    <Label fx:id="errorText" style="-fx-text-fill: #ff4d4f; -fx-font-size: 13px;"/>
</VBox>
