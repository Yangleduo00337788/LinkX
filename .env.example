# Compose project
LINKX_COMPOSE_PROJECT=linkx
LINKX_TIMEZONE=Asia/Shanghai

# Runtime profile
LINKX_PROFILE=prod
LINKX_SERVER_PORT=8080
LINKX_API_BASE_URL=http://localhost:8080
LINKX_UPLOAD_URL=http://localhost:8080/uploads/

# Database
LINKX_DB_PORT=3306
LINKX_DB_NAME=linkx_im
LINKX_DB_USERNAME=linkx
LINKX_DB_PASSWORD=change_me_linkx_db_password
LINKX_DB_ROOT_PASSWORD=change_me_linkx_root_password

# Redis
LINKX_REDIS_PORT=6379
LINKX_REDIS_PASSWORD=change_me_linkx_redis_password

# JWT
LINKX_JWT_SECRET=PLEASE_CHANGE_ME_LINKX_JWT_SECRET_2026_32CHARS_MIN
LINKX_JWT_EXPIRATION=86400000
LINKX_JWT_REFRESH_EXPIRATION=604800000

# Security
# Comma-separated origin patterns, for example:
# LINKX_SECURITY_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,https://im.example.com
LINKX_SECURITY_ALLOWED_ORIGIN_PATTERNS=
LINKX_SECURITY_AUTH_RATE_LIMIT_ENABLED=true
LINKX_SECURITY_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
LINKX_SECURITY_AUTH_LOGIN_MAX_REQUESTS=10
LINKX_SECURITY_AUTH_REGISTER_MAX_REQUESTS=5
LINKX_SECURITY_AUTH_REFRESH_MAX_REQUESTS=20
LINKX_SECURITY_CAPTCHA_ENABLED=false
