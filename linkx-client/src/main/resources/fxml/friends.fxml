<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.linkx.client.FriendController" style="-fx-background-color: #f5f5f5;">
    <top>
        <HBox prefHeight="52" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-border-color: #e8e8e8; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="0" right="16" bottom="0" left="16"/></padding>
            <Label text="联系人" style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="0" VBox.vgrow="ALWAYS">
            <!-- 搜索 -->
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 12 16; -fx-border-color: #e8e8e8; -fx-border-width: 0 0 1 0;">
                <TextField fx:id="searchField" promptText="搜索" prefHeight="32" HBox.hgrow="ALWAYS" styleClass="wechat-search"/>
                <Button fx:id="searchBtn" text="搜索" prefHeight="32" prefWidth="60" styleClass="wechat-green"/>
                <Button fx:id="refreshBtn" text="刷新" prefHeight="32" prefWidth="60" styleClass="wechat-green"/>
            </HBox>

            <!-- Tab -->
            <TabPane prefHeight="500" VBox.vgrow="ALWAYS">
                <Tab text="好友列表">
                    <ListView fx:id="friendListView" style="-fx-background-color: white;"/>
                </Tab>
                <Tab text="好友申请">
                    <ListView fx:id="requestListView" style="-fx-background-color: white;"/>
                </Tab>
                <Tab text="搜索结果">
                    <ListView fx:id="searchResultView" style="-fx-background-color: white;"/>
                </Tab>
            </TabPane>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-padding: 8;">
            <Label fx:id="statusText" style="-fx-font-size: 12px; -fx-text-fill: #999;"/>
        </HBox>
    </bottom>
</VBox>
