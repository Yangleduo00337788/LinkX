<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.linkx.client.ChatController" style="-fx-background-color: #ededed;">
    <top>
        <HBox prefHeight="52" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-border-color: #e8e8e8; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="0" right="16" bottom="0" left="16"/></padding>
            <Label fx:id="chatTargetLabel" text="消息" style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="260" style="-fx-background-color: #f0f0f0;">
            <padding><Insets top="4" bottom="4" left="4" right="4"/></padding>
            <ListView fx:id="sessionList" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="0">
            <ListView fx:id="messageList" VBox.vgrow="ALWAYS" style="-fx-background-color: #ededed;"/>
            <HBox spacing="0" alignment="CENTER_LEFT" style="-fx-background-color: #f5f5f5; -fx-border-color: #e8e8e8; -fx-border-width: 1 0 0 0;">
                <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
                <TextField fx:id="messageInput" promptText="输入消息..." HBox.hgrow="ALWAYS" prefHeight="36" styleClass="wechat-input"/>
                <Button fx:id="sendBtn" text="发送(S)" prefHeight="36" prefWidth="70" styleClass="wechat-send"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
