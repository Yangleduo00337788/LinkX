<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20" prefWidth="400" prefHeight="500" style="-fx-background-color: #f5f5f5;">
    <padding>
        <Insets top="50" right="40" bottom="50" left="40"/>
    </padding>

    <Text text="LinkX IM" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-fill: #1890ff;"/>

    <Text text="用户登录" style="-fx-font-size: 18px; -fx-fill: #666;"/>

    <VBox spacing="10">
        <TextField fx:id="usernameField" promptText="用户名" prefHeight="40"/>
        <PasswordField fx:id="passwordField" promptText="密码" prefHeight="40"/>
    </VBox>

    <VBox spacing="10">
        <Button fx:id="loginBtn" text="登录" prefHeight="40" style="-fx-background-color: #1890ff; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5;"/>
        <Button fx:id="registerBtn" text="注册新账号" prefHeight="40" style="-fx-background-color: white; -fx-text-fill: #1890ff; -fx-font-size: 14px; -fx-background-radius: 5; -fx-border-color: #1890ff;"/>
    </VBox>

    <Text fx:id="errorText" style="-fx-fill: red; -fx-font-size: 12px;"/>
</VBox>
