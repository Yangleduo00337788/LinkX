<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefWidth="960" prefHeight="650" xmlns:fx="http://javafx.com/fxml" fx:controller="com.linkx.client.MainController">
    <left>
        <VBox prefWidth="220" styleClass="side-menu" spacing="0">
            <padding><Insets top="20" right="0" bottom="20" left="0"/></padding>

            <HBox alignment="CENTER" spacing="6">
                <padding><Insets bottom="24" left="20"/></padding>
                <Label text="LinkX" styleClass="menu-title"/>
            </HBox>

            <Button fx:id="profileBtn" text="个人资料" prefHeight="40" maxWidth="220" styleClass="menu-btn">
                <padding><Insets left="20"/></padding>
            </Button>

            <VBox styleClass="menu-separator" VBox.vgrow="NEVER"/>

            <Button fx:id="contactsBtn" text="联系人" prefHeight="40" maxWidth="220" styleClass="menu-btn">
                <padding><Insets left="20"/></padding>
            </Button>

            <Button fx:id="chatBtn" text="消息" prefHeight="40" maxWidth="220" styleClass="menu-btn">
                <padding><Insets left="20"/></padding>
            </Button>

            <VBox VBox.vgrow="ALWAYS"/>

            <Button fx:id="logoutBtn" text="退出登录" prefHeight="40" maxWidth="220" style="-fx-background-color: transparent; -fx-text-fill: #ff4d4f; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT;">
                <padding><Insets left="20"/></padding>
            </Button>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #ededed;"/>
    </center>
</BorderPane>
